# API Base URL for the FastAPI backend
# In dev, leave blank to use the Vite proxy. Vite forwards /api to http://localhost:8000 automatically.
# In production, set this to your deployed backend origin (e.g., https://api.yourdomain.com)
VITE_API_BASE_URL=

# WebSocket Base URL for the live camera stream
# In dev, leave blank to use the Vite proxy.
# In production, set this to your deployed backend WS origin (e.g., wss://api.yourdomain.com)
VITE_WS_BASE_URL=
